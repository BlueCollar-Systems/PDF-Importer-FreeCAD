# Normalize line endings: store text as LF in the repo.
# CRLF/LF churn previously made pdfcadcore_sync_check.py report false "drift"
# between the LF canonical core and CRLF checkouts. Keep repo content LF.
* text=auto eol=lf

*.py   text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.json text eol=lf
*.cfg  text eol=lf
*.toml text eol=lf
*.xml  text eol=lf

# Binary assets - never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.whl binary
*.dxf binary
*.dwg binary
*.dxf binary
*.dwg binary
